<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E611151A"
    android:baselineAligned="false"
    android:orientation="horizontal"
    android:padding="40dp">

    <ScrollView
        android:layout_width="380dp"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingEnd="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:text="@string/settings_title"
                android:textColor="#FFFFFFFF"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/columns_title"
                android:textColor="#CCFFFFFF"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <Button android:id="@+id/columns_minus" android:layout_width="64dp" android:layout_height="52dp" android:text="−" android:textSize="24sp" />
                <TextView android:id="@+id/columns_value" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:textColor="#FFFFFFFF" android:textSize="22sp" />
                <Button android:id="@+id/columns_plus" android:layout_width="64dp" android:layout_height="52dp" android:text="+" android:textSize="24sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/card_size_title"
                android:textColor="#CCFFFFFF"
                android:textSize="18sp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="64dp" android:gravity="center_vertical" android:orientation="horizontal">
                <Button android:id="@+id/card_minus" android:layout_width="64dp" android:layout_height="52dp" android:text="−" android:textSize="24sp" />
                <TextView android:id="@+id/card_value" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:textColor="#FFFFFFFF" android:textSize="22sp" />
                <Button android:id="@+id/card_plus" android:layout_width="64dp" android:layout_height="52dp" android:text="+" android:textSize="24sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/icon_size_title"
                android:textColor="#CCFFFFFF"
                android:textSize="18sp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="64dp" android:gravity="center_vertical" android:orientation="horizontal">
                <Button android:id="@+id/icon_minus" android:layout_width="64dp" android:layout_height="52dp" android:text="−" android:textSize="24sp" />
                <TextView android:id="@+id/icon_value" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:textColor="#FFFFFFFF" android:textSize="22sp" />
                <Button android:id="@+id/icon_plus" android:layout_width="64dp" android:layout_height="52dp" android:text="+" android:textSize="24sp" />
            </LinearLayout>

            <Button
                android:id="@+id/wallpaper_button"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="28dp"
                android:text="@string/choose_wallpaper" />
        </LinearLayout>
    </ScrollView>

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#30FFFFFF" />

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="36dp"
        android:layout_weight="1">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/apps_title"
            android:textColor="#FFFFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <ListView
            android:id="@+id/app_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="58dp"
            android:choiceMode="multipleChoice"
            android:divider="#24FFFFFF"
            android:dividerHeight="1dp"
            android:listSelector="@android:color/transparent"
            android:scrollbars="none" />

        <ProgressBar
            android:id="@+id/app_loading"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center" />
    </FrameLayout>
</LinearLayout>

