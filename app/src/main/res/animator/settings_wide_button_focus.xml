<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <set android:ordering="together">
            <objectAnimator android:propertyName="scaleX" android:valueTo="1" android:duration="120" />
            <objectAnimator android:propertyName="scaleY" android:valueTo="1" android:duration="120" />
            <objectAnimator android:propertyName="elevation" android:valueTo="12dp" android:duration="120" />
        </set>
    </item>
    <item>
        <set android:ordering="together">
            <objectAnimator android:propertyName="scaleX" android:valueTo="1" android:duration="100" />
            <objectAnimator android:propertyName="scaleY" android:valueTo="1" android:duration="100" />
            <objectAnimator android:propertyName="elevation" android:valueTo="2dp" android:duration="100" />
        </set>
    </item>
</selector>
